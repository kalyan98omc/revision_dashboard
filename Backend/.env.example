# ─────────────────────────────────────────────────────────────────────────────
#  ApexLearn · Environment Configuration
#  Copy to .env and fill in your values. NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask Core ───────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=CHANGE_ME_TO_LONG_RANDOM_STRING_MIN_64_CHARS

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://apexlearn:password@localhost:5432/apexlearn_dev
DATABASE_URL_TEST=postgresql://apexlearn:password@localhost:5432/apexlearn_test
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ── Redis (Rate limiting, caching, SocketIO message queue) ───────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_DIFFERENT_FROM_SECRET_KEY
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.7

# ── Security ─────────────────────────────────────────────────────────────────
BCRYPT_LOG_ROUNDS=12
RATE_LIMIT_DEFAULT=200 per day;50 per hour
RATE_LIMIT_AUTH=10 per minute
RATE_LIMIT_AI=30 per minute
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
MAX_CONTENT_LENGTH_MB=10

# ── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_FOLDER=./uploads
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,mp3,wav,m4a

# ── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=https://...
LOG_LEVEL=INFO
